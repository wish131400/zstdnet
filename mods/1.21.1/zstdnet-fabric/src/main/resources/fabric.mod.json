{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "Route Minecraft traffic through a local or server-side zstd proxy.",
  "license": "MIT",
  "authors": [
    "wish"
  ],
  "environment": "*",
  "entrypoints": {
    "main": [
      "cn.tohsaka.factory.zstdnet.Zstdnet"
    ],
    "client": [
      "cn.tohsaka.factory.zstdnet.client.ZstdnetClient"
    ]
  },
  "mixins": [
    "zstdnet.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "fabric-api": "*",
    "java": ">=21"
  }
}
